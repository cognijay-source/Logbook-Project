# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@your-project.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL_DIRECT=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Trigger.dev
TRIGGER_DEV_API_KEY=your-trigger-dev-api-key
TRIGGER_DEV_API_URL=https://api.trigger.dev

# Sentry
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=logbook-project
